# Carga: primero `../.env` (raíz del repo), luego `mobile/.env` (ver app.config.js).
# Si duplicas variables aquí, ESTE archivo gana sobre la raíz.
#
# Seguridad: todo lo que empiece por EXPO_PUBLIC_ se incrusta en el bundle y es legible
# en el cliente. No pongas claves de API del backend, secretos JWT, ni credenciales de
# terceros aquí; solo URLs públicas del API y flags de desarrollo.

# Obligatorio para iPhone/Android (Expo Go): IP LAN del PC donde corre uvicorn.
# Sustituye por la IPv4 de "Adaptador Wi‑Fi" en ipconfig (no 127.0.0.1).
# Si cambia el DHCP del router, actualiza esta línea.
EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# Alternativa: misma IP que METRO_HOST / Xcode; app.config genera http://IP:8000 en `extra.apiUrl`.
# DEV_METRO_HOST=192.168.1.10

# iOS físico con Apple ID personal (sin programa de pago): OBLIGATORIO. Sin esto Xcode no crea
# el perfil: Push + HealthKit “Verifiable Health Records” no están en equipos personales.
# Tras activarlo: `npx expo prebuild -p ios --clean` y luego `npx expo run:ios --device`.
# IOS_PERSONAL_TEAM=1

# Metro (Expo en este repo usa puerto 8080 en scripts/start-expo.cjs)
RCT_METRO_PORT=8080

# Opcional: si Expo Go muestra exp://127.0.0.1, descomenta y pon la misma IP que arriba.
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.10

# --- Web (Expo web / navegador) ---
# Por defecto NO hace falta: en localhost/127.0.0.1 el cliente usa el API en :8000 del mismo host.
# Si abres la web desde la LAN (http://TU_IP:8080), appEnv usa http://TU_IP:8000 solo.
# Solo define EXPO_PUBLIC_API_URL_WEB si necesitas forzar el API en web (p. ej. backend remoto).
# Cuidado: si pones http://127.0.0.1:8000 aquí, la web abierta desde OTRO dispositivo en la LAN fallará.
# EXPO_PUBLIC_API_URL_WEB=http://127.0.0.1:8000

# --- Login social ---
# Google client IDs publicos. Añade los mismos valores en GOOGLE_OAUTH_CLIENT_IDS del backend.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
