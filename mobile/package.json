{
  "name": "nutriforce-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node ./scripts/start-expo.cjs",
    "start:localhost": "expo start --port 8080 --localhost",
    "start:tunnel": "expo start --port 8080 --tunnel",
    "android": "node ./scripts/start-expo.cjs --android",
    "adb:reverse-api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/adb-reverse-api.ps1",
    "logcat:ime": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-logcat-ime.ps1",
    "ios": "node ./scripts/start-expo.cjs --ios",
    "web": "node ./scripts/start-expo.cjs --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "node ./scripts/lint-mobile.js",
    "check": "npm run typecheck && npm run lint",
    "test": "npm run check",
    "test:wearables": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.10.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@tanstack/react-query": "^5.75.0",
    "babel-preset-expo": "~54.0.10",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "html2pdf.js": "^0.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.56.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health": "^1.13.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "typewriter4react-native": "^0.5.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.0",
    "dotenv": "^16.6.1",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "postcss": "^8.5.15",
    "uuid": "^14.0.0"
  }
}
