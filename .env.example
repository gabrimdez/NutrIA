# --- Base de datos (Neon u otro Postgres) ---
# En Neon: Dashboard → Connection string → copia la URI y usa el prefijo postgresql+asyncpg://
# Ejemplo: postgresql+asyncpg://neondb_owner:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Secreto para firmar JWT de login/registro (cadena larga aleatoria; no uses el de ejemplo en producción)
JWT_SECRET=change-me-genera-un-secreto-largo-aleatorio

# --- Insignias (badges) ---
# CRUD admin y recompute: cabecera HTTP `X-Admin-Key` con este valor.
# Debe tener al menos 32 caracteres. Dejar vacio desactiva rutas admin (503).
BADGES_ADMIN_API_KEY=
# Caps diarios (acciones que cuentan en ledger tras anti-abuso)
BADGE_DAILY_CAP_BARCODE_SCAN=10
BADGE_DAILY_CAP_PHOTO_ANALYZE=10
BADGE_DAILY_CAP_FOOD_SEARCH=10
BADGE_DAILY_CAP_NUTRITION_SEARCH=10
# Día completo: separación mínima entre comidas (minutos)
BADGE_COMPLETE_DAY_MIN_MINUTES_BETWEEN_MEALS=90
# Rachas: días de gracia tras el día calendario para contar el registro (anti backfill agresivo)
BADGE_STREAK_GRACE_DAYS_AFTER_CALENDAR_DAY=1

# --- IA (Groq) ---
# Consola: https://console.groq.com — API compatible con OpenAI en GROQ_BASE_URL
# Una clave, o varias separadas por coma (máx. 4): ante 429/cuota se prueba la siguiente.
# GROQ_API_KEYS=gsk_a...,gsk_b...,gsk_c...,gsk_d...
GROQ_API_KEY=
GROQ_API_KEYS=
# Texto, chat con herramientas y planes (JSON)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# JSON de planes semanales (recomendado: llama-3.1-8b-instant en free tier)
GROQ_PLAN_MODEL=llama-3.1-8b-instant
# Máx. tokens de salida por petición de plan (bajar a 1536 si Groq devuelve 413)
GROQ_PLAN_MAX_OUTPUT_TOKENS=2048
# En free tier: false evita una llamada de 7 días que suele truncarse y gastar TPM
GROQ_PLAN_TRY_SINGLE_WEEK_CALL=false
# Pausas (segundos): antes del 1er día, entre días, y tras cada respuesta Groq (clave en free tier ~6000 TPM)
GROQ_PLAN_DELAY_BEFORE_DAYS_SECONDS=8
GROQ_PLAN_DELAY_BETWEEN_DAYS_SECONDS=6
GROQ_PLAN_THROTTLE_AFTER_CALL_SECONDS=12
# Fotos de comidas (modelo multimodal; lista actual: https://console.groq.com/docs/models )
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Nutrition providers ---
# FatSecret: https://platform.fatsecret.com — OAuth2 client credentials
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
# LogMeal: https://logmeal.com/api — API key for food photo analysis
LOGMEAL_API_KEY=
# Open Food Facts (no key required): User-Agent and base URL
OFF_USER_AGENT=NutrIA/1.0 (contact: dev; +https://github.com/nutriforce)
OFF_API_BASE_URL=https://world.openfoodfacts.org
# Global nutrition timeouts and cache
NUTRITION_TIMEOUT_MS=10000
NUTRITION_CACHE_TTL_SECONDS=3600

# Backend
BACKEND_URL=http://localhost:8000
# Orígenes extra para CORS (coma). Solo hace falta si ENVIRONMENT no es development o el front no es localhost/IP privada.
# Ejemplo Expo Web por IP: CORS_ORIGINS=http://172.31.28.105:8080
CORS_ORIGINS=
# Expo Go / móvil en la misma red (IP Wi‑Fi de este PC)
EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
SECRET_KEY=change-me-in-production
# En despliegue real usa production para no exponer detalles internos en errores/logs.
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Email / recuperacion de contrasena ---
# URL que recibira el token. En web/Expo local suele ser http://localhost:8080/auth/reset-password.
# En production debe ser HTTPS o el backend no arrancara.
PASSWORD_RESET_URL=http://localhost:8080/auth/reset-password
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_URL=http://localhost:8080/auth/verify-email
EMAIL_VERIFICATION_TOKEN_MINUTES=1440
# Configura SMTP en produccion para poder enviar los enlaces.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_USE_TLS=false

# --- Login social ---
# Client IDs publicos permitidos por el backend para validar ID tokens de Google.
# Incluye web/iOS/Android separados por coma si usas varias plataformas.
GOOGLE_OAUTH_CLIENT_IDS=
# Sign in with Apple nativo iOS: bundle id de la app. Para web haría falta un Services ID separado.
APPLE_CLIENT_IDS=com.siwebai.nutria

# Cupos Free vs Premium (backend). Premium real: columna profiles.subscription_tier = 'premium'
# FREE_CHAT_USER_MESSAGES_PER_MONTH=10
# FREE_VISION_ANALYSES_PER_MONTH=1
# FREE_PLAN_REGENERATIONS_PER_WEEK=1
# PREMIUM_CHAT_USER_MESSAGES_PER_DAY=8000
# Lista opcional de user_id (Supabase) tratados como Premium sin tocar la BD (solo dev)
# NUTRIFORCE_PREMIUM_OVERRIDE_USER_IDS=uuid1,uuid2
# Correos extra tratados como Premium sin tocar la BD (coma); válido en cualquier ENVIRONMENT.
# NUTRIFORCE_PREMIUM_OVERRIDE_EMAILS=acemengab@gmail.com,lucas.perezpract@siweb.es
